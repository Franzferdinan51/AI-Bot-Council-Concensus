# AI Council Chamber Configuration
# Copy this file to .env and fill in your actual values

# Primary Provider: Alibaba Bailian
BAILIAN_API_KEY=your-bailian-api-key-here
BAILIAN_ENDPOINT=https://coding-intl.dashscope.aliyuncs.com/v1

# Model Configuration (BAILIAN ONLY)
SPEAKER_MODEL=bailian/qwen3.5-plus
RESEARCH_MODEL=bailian/MiniMax-M2.5
VISION_MODEL=bailian/kimi-k2.5
FAST_MODEL=bailian/glm-5
BACKUP_MODEL=bailian/glm-4.7
CODING_MODEL=bailian/qwen3-coder-plus

# Local Fallback (Optional): LM Studio
LM_STUDIO_ENDPOINT=http://localhost:1234/v1
LM_STUDIO_MODELS=jan-v3-4b,qwen3-vl-8b

# Server Configuration
PORT=3003
HOST=0.0.0.0
NODE_ENV=development

# Logging
LOG_LEVEL=info
DISABLE_THOUGHT_LOGGING=false
