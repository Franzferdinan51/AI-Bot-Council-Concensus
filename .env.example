# AI Council Chamber Configuration
# Copy this file to .env and fill in your actual values

# Primary Provider: MiniMax M2.7
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_ENDPOINT=https://coding-intl.dashscope.aliyuncs.com/v1

# Model Configuration (MiniMax + LM Studio + ChatGPT)
SPEAKER_MODEL=MiniMax-M2.7
RESEARCH_MODEL=MiniMax-M2.7
VISION_MODEL=lmstudio/qwen3-vl-8b-thinking
FAST_MODEL=jan-v3-4b-base-instruct
BACKUP_MODEL=qwen/qwen3.5-9b
CODING_MODEL=MiniMax-M2.7

# Local Fallback (Optional): LM Studio
LM_STUDIO_ENDPOINT=http://localhost:1234/v1
LM_STUDIO_MODELS=jan-v3-4b,qwen3-vl-8b

# Server Configuration
PORT=3003
HOST=0.0.0.0
NODE_ENV=development

# Logging
LOG_LEVEL=info
DISABLE_THOUGHT_LOGGING=false
